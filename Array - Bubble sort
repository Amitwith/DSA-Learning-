#include <iostream>
using namespace std;

int main() {
    int n;
    int arr[50];
    bool swaptime = 0;
    cout << "Enter array Length : "<< endl;
    cin >> n;
    cout << "Enter Element in array : "<< endl;
    for(int i = 0; i < n; i++) {
        cin >> arr[i];
    }

    for(int i = n - 2; i >= 0; i--) {

        for(int j = 0; j <= i; j++) {

            if(arr[j] > arr[j + 1]) {
                swap(arr[j],arr[j+1]);
                swaptime = 1;
            }
        }
        if(swaptime == 0) {
            break;
        }

    }

    for(int i = 0; i < 5; i++) {
        cout << arr[i]<< endl;
    }


    return 0;
}
