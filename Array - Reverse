#include <iostream>
using namespace std;



// Reverse array
int main() {

    int arr[6] = {1,2,3,4,15,6};
    int start = 0,end = 6;

    while(start < end) {
        swap(arr[start],arr[end]);
        start ++;
        end --;
    }
    for(int i = 1; i<=6; i++)
        cout << arr[i] << endl;



    return 0;
}
