#include <iostream>
using namespace std;

int main() {

    int size,key;
    cout << "Enter Array Length : " << endl;
    cin >> size;
    int arr[50];
    cout << "Enter Element in Array : " << endl;
    for(int i = 0; i < size; i++) {
        cin >> arr[i];

    }
    cout << "Enter Element You Want to Find : " << endl;
    cin >> key;

    int mid, start = 0, end = size -1;
    bool found = false;

    while(start <= end) {

        mid = (start + end)/2;

        if(arr[mid] == key) {
            cout << "Element is Founded" << endl;
            found = true;
            break;
        }
        else if(arr[mid] < key) {
            start = mid + 1;
        }
        else
            end = mid - 1;


    }

    if(found == 0) {
        cout << "Element is not found  " << endl;

    }





    return 0;
}
